# ------------------------------------------------------------------------------
# Deepfield configuration. Copy this file to .env and fill in your own keys.
# .env is gitignored and never committed. Only VITE_* values reach the browser;
# every other secret stays server-side.
#
#   cp .env.example .env
#
# Nothing below is required to try the app offline: `npm run demo` and
# `?driver=fake` run a deterministic script with no keys at all.
# ------------------------------------------------------------------------------

# --- Inference (required for live mode) ---------------------------------------
# Vultr Serverless Inference key. Create one at https://www.vultr.com
# (Serverless Inference). The key never reaches the browser: the server proxies
# an allowlist of paths only.
VULTR_INFERENCE_API_KEY=
VULTR_BASE_URL=https://api.vultrinference.com/v1

# --- Private-link demo lock (optional) ----------------------------------------
# If set, live inference requires opening the app with ?key=<DEMO_TOKEN>. Leave
# empty for an open deployment, or use AUTH_ENABLED below for real accounts.
DEMO_TOKEN=

# --- Multi-user mode (optional, VM deployment) --------------------------------
# AUTH_ENABLED=1 turns on signup/login, per-account server-side conversation
# storage, and per-account daily inference quotas.
AUTH_ENABLED=
USER_DAILY_LIMIT=150
GLOBAL_DAILY_LIMIT=5000

# --- Transactional mail (optional: email verification + password reset) -------
# Any SMTP submission relay over implicit TLS (port 465). Without it, signups are
# auto-verified and password reset is disabled. SPF/DKIM/DMARC live on the relay.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com
APP_ORIGIN=https://your-domain.example

# --- Cloudflare Turnstile (optional: captcha on signup + login) ---------------
# Create a widget at https://dash.cloudflare.com (Turnstile). The sitekey is
# public and shipped to the browser (VITE_ prefix); the secret stays server-side.
# When TURNSTILE_SECRET is set, signup and login require a verified widget token.
VITE_TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# --- Speech relay (optional: mic input + spoken verdicts) ---------------------
# NVIDIA hosted API key for the TTS/ASR relay (tools/tts-relay). Generate one at
# https://build.nvidia.com. Without it, the mic button is hidden and TTS falls
# back to the browser voice.
NVIDIA_API_KEY=

# --- Offsite backup (optional, VM deployment) ---------------------------------
# rsync target for the hourly data backup (user@host:/path). A dedicated SSH key
# is generated on the VM at first deploy and must be authorized on this host.
BACKUP_REMOTE=
BACKUP_SSH_PORT=22

# --- Production monitor (optional, VM deployment) -----------------------------
# The monitor (deploy/monitor.mjs, a systemd timer every 10 min) mails this
# address about new signups, brute-force lockouts, quota pressure, service
# health, and a daily digest. Empty = monitor does nothing. Reuses SMTP_* above.
# Optional tuning: MONITOR_DIGEST_HOUR (UTC, default 8), MONITOR_QUOTA_PCT (80),
# MONITOR_SIGNUP_SPIKE (5 new accounts per run).
MONITOR_EMAIL=
